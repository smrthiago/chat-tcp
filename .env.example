# ===== SERVIDOR =====
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
MAX_CLIENTS=50

# ===== REDE =====
BUFFER_SIZE=4096
SOCKET_TIMEOUT=300
MAX_MESSAGE_SIZE=65536

# ===== RECONEXÃO =====
RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=2

# ===== SEGURANÇA =====
ENABLE_ENCRYPTION=true
PING_INTERVAL=30
PING_TIMEOUT=90

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== DESENVOLVIMENTO =====
DEBUG=false
